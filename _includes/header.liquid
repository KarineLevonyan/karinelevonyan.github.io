<header style="background:#1f2937; padding:16px 24px;">
  <nav style="display:flex; gap:20px; align-items:center; flex-wrap:wrap;">
    <a href="{{ '/' | relative_url }}" style="color:white; text-decoration:none; font-weight:700;">
      {{ site.title }}
    </a>

    {% assign sorted_pages = site.pages | sort: "nav_order" %}
    {% for p in sorted_pages %}
      {% if p.nav == true and p.permalink != '/' %}
        <a href="{{ p.url | relative_url }}" style="color:white; text-decoration:none;">
          {{ p.title }}
        </a>
      {% endif %}
    {% endfor %}
  </nav>
</header>